{
  "name": "project-magi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:native": "node -e \"if(process.platform==='darwin'){require('child_process').execSync('bash scripts/build-native.sh',{stdio:'inherit'})}else{console.log('Skipping native build (not macOS)')}\"",
    "rebuild:node-addon": "node scripts/rebuild-better-sqlite3.js node",
    "rebuild:electron-addon": "node scripts/rebuild-better-sqlite3.js electron",
    "postinstall": "npm run rebuild:electron-addon",
    "dev": "npm run build:native && npm run rebuild:electron-addon && electron-vite dev",
    "build": "npm run build:native && electron-vite build",
    "preview": "electron-vite preview",
    "test": "npm run rebuild:node-addon && vitest run; npm run rebuild:electron-addon",
    "test:reliability": "vitest run src/main/ipc/__tests__/chat-reliability.test.ts src/main/ipc/__tests__/chat-diagnostics.test.ts src/main/ipc/__tests__/chat-contracts.test.ts src/main/ipc/__tests__/data-keys.test.ts src/main/ipc/__tests__/chat-key-resolution.test.ts src/main/ipc/__tests__/openai-prompt-cache.test.ts",
    "test:watch": "npm run rebuild:node-addon && vitest; npm run rebuild:electron-addon",
    "eval:refresh": "node scripts/extract-chat-regressions.mjs",
    "mcp": "node out/main/mcp.js"
  },
  "main": "./out/main/index.js",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/openai": "^3.0.35",
    "@milkdown/crepe": "^7.18.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.99",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
